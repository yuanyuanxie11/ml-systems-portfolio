        <mxCell id="footer-vol" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1E2761;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacingLeft=8;" value="DATA VOLUMES (ESTIMATED)&#xa;&#xa;• Raw Ingestion: ~37.5 TB / year&#xa;• Curated (Cleaned): ~15 TB / year&#xa;• Enriched: ~5 TB / year&#xa;• Consumption (Features): ~2 TB / year&#xa;• Total Managed in S3: ~59.5 TB / year" vertex="1">
