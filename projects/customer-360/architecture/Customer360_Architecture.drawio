        <mxCell id="footer-rpo" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1E2761;fontSize=10;fontStyle=0;align=left;verticalAlign=top;spacingLeft=8;" value="RPO / RTO&#xa;&#xa;• RPO: 15 minutes (S3 + DynamoDB)&#xa;• RTO: 4 hours (region outage)&#xa;• Backup Retention: 35 days (S3),&#xa;  7 years (Glacier Deep Archive)" vertex="1">
          <mxGeometry height="90" width="240" x="240" y="1990" as="geometry" />
        </mxCell>
